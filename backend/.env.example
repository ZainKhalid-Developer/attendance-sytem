# Local development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_attendance
JWT_SECRET=change-this-to-a-long-random-string
PORT=4000

# --- Railway / production ---
# DATABASE_URL is provided automatically when you add a Postgres plugin.
# Reference it in your service variables as: ${{ Postgres.DATABASE_URL }}
#
# PGSSL: leave unset to auto-detect (SSL on for public hosts, off for
# localhost and *.railway.internal). Force with "true" or "false".
# PGSSL=true
#
# UPLOAD_DIR: absolute path for storing selfies. Point this at a mounted
# Railway Volume so uploads survive redeploys (the container FS is ephemeral).
# UPLOAD_DIR=/data/uploads
